rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is current user one of super admins?
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "mahmoudsruby@gmail.com" ||
        request.auth.token.email == "mahmoudabdelrauf84@gmail.com"
      );
    }

    // Helper: Is the user an administrator?
    // Checks super-admin email first, then user document flags.
    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile.isAdmin == true
      );
    }

    // User Profiles: Users can only read their own, Admins can do both.
    // Fixed privilege escalation bug: users cannot modify their own isAdmin field.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && (isAdmin() || (request.auth.uid == userId && !('isAdmin' in request.resource.data) && (!('profile' in request.resource.data) || !('isAdmin' in request.resource.data.profile))));
      allow update: if request.auth != null && (isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']) && (!('profile' in request.resource.data) || !('isAdmin' in request.resource.data.profile) || request.resource.data.profile.isAdmin == resource.data.profile.isAdmin)));
      allow delete: if isAdmin();
    }

    // Course Reviews: Nested structure /course_reviews/{courseId}/reviews/{reviewId}
    match /course_reviews/{courseId}/reviews/{reviewId} {
      allow read: if true; // Publicly readable
      allow create: if isSignedIn(); // Registered users can review
      allow update, delete: if isSignedIn() && 
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Public catalog (optional) + admin lifecycle moderation.
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Dynamic CMS Content: Public read for free courses, purchased access for premium
    match /dynamic_courses/{courseId} {
      allow read: if true; // Course metadata is public
      allow write: if isAdmin();
    }

    // Premium course content access control
    match /dynamic_lessons/{lessonId} {
      allow read: if resource.data.courseId == null ||
        get(/databases/$(database)/documents/dynamic_courses/$(resource.data.courseId)).data.pricing.type == 'free' ||
        (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedCourses.hasAny([resource.data.courseId]));
      allow write: if isAdmin();
    }

    match /dynamic_challenges/{challengeId} {
      allow read: if resource.data.courseId == null ||
        get(/databases/$(database)/documents/dynamic_courses/$(resource.data.courseId)).data.pricing.type == 'free' ||
        (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedCourses.hasAny([resource.data.courseId]));
      allow write: if isAdmin();
    }

    // Discussions: Public read, authenticated write
    match /discussions/{threadId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.authorId || isAdmin()
      );
    }

    // Lesson Comments: Public read, authenticated write
    match /lesson_comments/{commentId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.authorId || isAdmin()
      );
    }

    // User purchases: Private to user
    match /users/{userId}/purchases/{purchaseId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Admin analytics + settings
    match /system/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Platform announcements are public read, admin managed.
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Moderation queue is admin only.
    match /moderation_queue/{flagId} {
      allow read, write: if isAdmin();
    }

    // Revenue transactions: create on payment webhook/backend, admin read.
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Default Deny: All other collections are private
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
